NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server only. Separate backup keys with commas, semicolons, spaces, or new lines.
# Never prefix these variables with NEXT_PUBLIC_.
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
GEMINI_VISION_MODEL=gemini-3.5-flash
GEMINI_TEXT_MODEL=gemini-3.5-flash

# Free fallback with vision/OCR support.
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Providers are tried from left to right. Each provider rotates through all its keys.
AI_VISION_PROVIDER_ORDER=gemini,groq
AI_TEXT_PROVIDER_ORDER=gemini,groq

# Server-only Supabase key used by the Zalo webhook.
SUPABASE_SECRET_KEY=

# Zalo Bot credentials. Do not prefix these with NEXT_PUBLIC_.
ZALO_BOT_TOKEN=
ZALO_WEBHOOK_SECRET=

# Fill this after the production deployment exists.
ZALO_WEBHOOK_URL=https://your-project.vercel.app/api/zalo/webhook

# Keep configurable until the Zalo Bot send-message endpoint is confirmed.
ZALO_SEND_MESSAGE_URL=
